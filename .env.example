# ---------- PostgreSQL ----------
POSTGRES_DB=techcellshop
POSTGRES_USER=change_me_postgres_user
POSTGRES_PASSWORD=change_me_postgres_password

# ---------- RabbitMQ ----------
RABBITMQ_USER=change_me_rabbit_user
RABBITMQ_PASSWORD=change_me_rabbit_password
RABBITMQ_VHOST=/techcellshop

# ---------- App / JWT ----------
SECURITY_JWT_SECRET=change_me_long_random_secret_with_at_least_32_characters
SECURITY_JWT_EXPIRATION_MS=3600000

# ---------- pgAdmin ----------
PGADMIN_EMAIL=change_me_email_for_pgadmin
PGADMIN_PASSWORD=change_me_pgadmin_password

# ---------- Optional observability ----------
GRAFANA_ADMIN_USER=change_me_grafana_user
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password