    {
      "name": "4️⃣ PAYMENT FLOW",
      "item": [
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"TXN-001-{{$timestamp}}\",\n  \"amount\": 3999.90,\n  \"reason\": \"Payment confirmed by customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/orders/{{orderId}}/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "orders", "{{orderId}}", "confirm"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payment confirmed successfully', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Payment status is CONFIRMED', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.paymentStatus).to.equal('CONFIRMED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Fail Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"TXN-FAIL-{{$timestamp}}\",\n  \"amount\": 3999.90,\n  \"reason\": \"Insufficient funds\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/orders/{{orderId}}/fail",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "orders", "{{orderId}}", "fail"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payment marked as failed', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
